{
  "name": "decifra",
  "version": "0.0.4",
  "description": "Formatação humanizada de números, datas, tamanhos e durações para JavaScript e TypeScript. pt-BR de primeira classe.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "humanize",
    "format",
    "i18n",
    "pt-br",
    "intl",
    "naturaltime",
    "naturalsize",
    "intcomma",
    "ordinal"
  ],
  "author": "Gabriel Silva",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oGabrielSilva/decifra.js.git"
  },
  "homepage": "https://github.com/oGabrielSilva/decifra.js#readme",
  "bugs": "https://github.com/oGabrielSilva/decifra.js/issues",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.6.0",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
